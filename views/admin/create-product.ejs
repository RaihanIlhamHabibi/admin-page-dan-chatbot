<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <span class="badge">Tambah Produk</span>
    <h1>Tambah Produk Baru</h1>
    <p>Tambahkan produk baru tanpa mengubah jumlah total produk awal jika tidak diperlukan.</p>
  </div>
  <a href="/admin/products" class="btn secondary">Kembali</a>
</div>

<% if (error) { %>
  <div class="alert error"><%= error %></div>
<% } %>
<% if (success) { %>
  <div class="alert success"><%= success %></div>
<% } %>

<section class="card form-card">
  <form method="POST" action="/admin/products">
    <div class="form-group">
      <label for="product_code">Kode Produk</label>
      <input type="text" id="product_code" name="product_code" placeholder="Contoh: PRD011" required>
    </div>

    <div class="form-group">
      <label for="product_name">Nama Produk</label>
      <input type="text" id="product_name" name="product_name" placeholder="Contoh: Mouse Wireless" required>
    </div>

    <div class="form-group">
      <label for="category">Kategori</label>
      <input type="text" id="category" name="category" placeholder="Contoh: Aksesoris Komputer" required>
    </div>

    <div class="form-group">
      <label for="price">Harga</label>
      <input type="number" id="price" name="price" placeholder="Contoh: 120000" min="1" required>
    </div>

    <div class="form-group">
      <label for="quantity">Stok</label>
      <input type="number" id="quantity" name="quantity" placeholder="Contoh: 20" min="0" required>
    </div>

    <div class="form-group">
      <label for="description">Deskripsi</label>
      <textarea id="description" name="description" rows="4" placeholder="Deskripsi produk"></textarea>
    </div>

    <button type="submit" class="btn primary full-width">Tambah Produk</button>
  </form>
</section>

<%- include('../partials/footer') %>
