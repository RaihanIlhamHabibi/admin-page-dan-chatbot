# =============================
# SERVER CONFIG
# =============================
PORT=3000

# =============================
# CHATBOT AI CONFIG
# Pilihan provider:
# demo | ollama | openai | deepseek | gemini
# =============================
AI_PROVIDER=demo

# Prompt bawaan untuk gaya jawaban AI
AI_SYSTEM_PROMPT=Jawab dengan bahasa Indonesia yang singkat, jelas, sopan, dan membantu.

# Fallback API key dan model umum.
# Bisa dipakai kalau tidak ingin pakai variabel khusus provider.
AI_API_KEY=
AI_MODEL=

# =============================
# OPENAI / CHATGPT CONFIG
# Gunakan kalau AI_PROVIDER=openai
# =============================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# =============================
# DEEPSEEK CONFIG
# Gunakan kalau AI_PROVIDER=deepseek
# =============================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# =============================
# GEMINI CONFIG
# Gunakan kalau AI_PROVIDER=gemini
# =============================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# =============================
# OLLAMA LOCAL CONFIG
# Gunakan kalau AI_PROVIDER=ollama
# Pastikan Ollama sudah berjalan di komputer.
# =============================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
